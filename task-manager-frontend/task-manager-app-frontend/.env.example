# Frontend environment variables
# Copy this file to .env.development for local development.
# Production values are set in .env.production.

# Base URL for direct blob access (Azurite locally, empty in production)
VITE_BLOB_BASE=http://127.0.0.1:10000/devstoreaccount1

# Blob path prefix used by Front Door routing rules (production only)
VITE_FD_BLOB_PREFIX=
